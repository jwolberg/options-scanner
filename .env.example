# Copy this file to .env and fill in your keys
# Never commit .env to version control

# Set TV_DEMO=1 to run in demo mode (no TV_API_KEY required)...
# ...OR Set TV_DEMO=0 and use a valid TV_API_KEY
TV_DEMO=1

# Trading Volatility API key (get one at https://tradingvolatility.com/api/v2/docs)
TV_API_KEY=your_tv_api_key_here…

# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here…

# Proxy server port (default: 3001)
PORT=3001
